# Copy to .env (gitignored) and fill in. The pipeline reads these at runtime.

# Required for LLM-driven ingesters (earnings_release, etc.)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — overrides the default model (claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional — User-Agent for SEC EDGAR requests (script default is fine for low-volume use).
# Format: "<Org or project name> <admin email>"
# SEC_UA=your-org admin@your-org.example
